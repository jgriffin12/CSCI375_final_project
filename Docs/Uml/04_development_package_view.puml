@startuml Development

package "frontend" {
  [index.html]
  [style.css]
  [script.js]
}

package "apps.routes" {
  [authRoutes]
  [recordRoutes]
  [adminRoutes]
}

package "apps.controllers" {
  [AuthController]
  [RecordController]
}

package "apps.services" {
  [AuthService]
  [MFAService]
  [RecordService]
  [AccessControlService]
}

package "apps.repositories" {
  [UserRepository]
  [RecordRepository]
  [AuditRepository]
}

package "apps.security" {
  [PasswordHasher]
  [MFAFactory]
  [MFAStrategy]
  [SensitiveDataMasker]
  [Tokenizer]
}

package "apps.models" {
  [User]
  [MedicalRecord]
  [SecurityEvent]
}

[script.js] --> [authRoutes]
[script.js] --> [recordRoutes]

[authRoutes] --> [AuthController]
[recordRoutes] --> [RecordController]

[AuthController] --> [AuthService]
[RecordController] --> [RecordService]

[AuthService] --> [UserRepository]
[AuthService] --> [MFAService]
[RecordService] --> [RecordRepository]

[AuthService] --> [PasswordHasher]
[MFAService] --> [MFAFactory]
[RecordService] --> [SensitiveDataMasker]
[RecordService] --> [Tokenizer]

[UserRepository] --> [User]
[RecordRepository] --> [MedicalRecord]
[AuditRepository] --> [SecurityEvent]

@enduml