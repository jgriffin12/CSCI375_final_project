@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false

title Development View - Package Structure

package "Apps" {
  package "Routes" {
    [authRoutes.py]
    [recordRoutes.py]
    [adminRoutes.py]
  }

  package "Controllers" {
    [loginController.py]
    [recordController.py]
    [adminController.py]
  }

  package "Models" {
    [user.py]
    [role.py]
    [permission.py]
    [record.py]
    [session.py]
    [securityEvent.py]
  }

  package "Services" {
    [authSvc.py]
    [mfaSvc.py]
    [accessControlSvc.py]
    [recordSvc.py]
    [auditLogger.py]
  }

  package "Security" {
    [PassHash.py]
    [masker.py]
    [Tokenizer.py]
    [mfaStrategies.py]
    [mfaFactory.py]
  }

  package "Repositories" {
    [userRepo.py]
    [recordRepo.py]
    [auditRepo.py]
  }

  package "Templates" {
    [login.html]
    [dashboard.html]
  }

  package "Static" {
    [styles.css]
  }

  [main.py]
}

package "Tests" {
  [testAuthSvc.py]
  [testAccessControlSvc.py]
  [testAuditLogger.py]
  [testMasker.py]
  [testPropAuth.py]
  [testRoutes.py]
}

package "Docs" {
  [UML]
}

[main.py] --> [authRoutes.py]
[main.py] --> [recordRoutes.py]
[main.py] --> [adminRoutes.py]

[authRoutes.py] --> [loginController.py]
[recordRoutes.py] --> [recordController.py]
[adminRoutes.py] --> [adminController.py]

[loginController.py] --> [authSvc.py]
[recordController.py] --> [recordSvc.py]
[adminController.py] --> [auditLogger.py]

[authSvc.py] --> [userRepo.py]
[authSvc.py] --> [PassHash.py]
[authSvc.py] --> [mfaSvc.py]
[authSvc.py] --> [auditLogger.py]

[mfaSvc.py] --> [mfaFactory.py]
[mfaFactory.py] --> [mfaStrategies.py]

[recordSvc.py] --> [recordRepo.py]
[recordSvc.py] --> [accessControlSvc.py]
[recordSvc.py] --> [masker.py]
[recordSvc.py] --> [Tokenizer.py]
[recordSvc.py] --> [auditLogger.py]

[auditLogger.py] --> [auditRepo.py]

[testAuthSvc.py] --> [authSvc.py]
[testAccessControlSvc.py] --> [accessControlSvc.py]
[testAuditLogger.py] --> [auditLogger.py]
[testMasker.py] --> [masker.py]
[testPropAuth.py] --> [authSvc.py]
[testRoutes.py] --> [authRoutes.py]
[testRoutes.py] --> [recordRoutes.py]
@enduml