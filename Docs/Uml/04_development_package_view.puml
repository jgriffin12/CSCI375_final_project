@startuml 04_development_package_view
title Development / Package View - CJ Secure 
skinparam packageStyle rectangle

package "frontend" {
  [UI (HTML/JS)]
}

package "routes" {
  [Auth Routes]
  [Record Routes]
  [Admin Routes]
}

package "controllers" {
  [LoginController]
  [RecordController]
  [AdminController]
}

package "services" {
  [AuthService]
  [RecordService]
  [MFAService]
  [AuditLogger]
}

package "repositories" {
  [UserRepository]
  [RecordRepository]
  [AuditRepository]
}

package "models" {
  [User]
  [Record]
  [SecurityEvent]
}

package "security" {
  [PasswordHasher]
  [MFAFactory / Strategies]
  [Masker / Tokenizer]
}

' Flow
[UI (HTML/JS)] --> [Auth Routes]
[UI (HTML/JS)] --> [Record Routes]

[Auth Routes] --> [LoginController]
[Record Routes] --> [RecordController]
[Admin Routes] --> [AdminController]

[LoginController] --> [AuthService]
[RecordController] --> [RecordService]
[AdminController] --> [AuditLogger]

[AuthService] --> [UserRepository]
[AuthService] --> [MFAService]

[RecordService] --> [RecordRepository]

[AuditLogger] --> [AuditRepository]

[UserRepository] --> [User]
[RecordRepository] --> [Record]
[AuditRepository] --> [SecurityEvent]

' Security integration
[AuthService] --> [PasswordHasher]
[MFAService] --> [MFAFactory / Strategies]
[RecordService] --> [Masker / Tokenizer]

@enduml
