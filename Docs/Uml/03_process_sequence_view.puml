@startuml

actor User
participant "Frontend" as FE
participant "Auth Route" as Route
participant "AuthService" as Auth
participant "UserRepository" as Repo
participant "MFAService" as MFA
participant "MFAFactory" as Factory
participant "MFAStrategy" as Strategy
participant "AuditLogger" as Audit

User -> FE : enter username/password
FE -> Route : POST /login
Route -> Auth : login(username, password)
Auth -> Repo : find user
Repo --> Auth : user

Auth -> MFA : send MFA code
MFA -> Factory : create strategy
Factory --> MFA : strategy
MFA -> Strategy : send code

Auth -> Audit : log login attempt
Auth --> Route : MFA required
Route --> FE : response

User -> FE : enter MFA code
FE -> Route : POST /verify-mfa
Route -> Auth : verify code
Auth -> MFA : verify MFA
MFA -> Strategy : verify code
Strategy --> MFA : valid/invalid
MFA --> Auth : result
Auth -> Audit : log MFA result
Auth --> Route : access granted
Route --> FE : login complete

@enduml