@startuml 03_process_sequence_view
title Process / Sequence View - Login, MFA, and Role-Based Access

actor User
participant "Frontend" as FE
participant "Auth Route" as AR
participant "LoginController" as LC
participant "AuthService" as AS
participant "UserRepository" as UR
participant "MFAService" as MS
participant "AuditLogger" as AL

User -> FE : Enter email
FE -> AR : POST /check-email
AR -> LC : check email
LC -> AS : check_email(email)
AS -> UR : find_by_email(email)
UR --> AS : user / none
AS --> FE : existing or new user

User -> FE : Enter username, role, password
FE -> AR : POST /login
AR -> LC : login request
LC -> AS : authenticate(user info)
AS -> UR : find_by_username(username)
UR --> AS : user

alt valid credentials
  AS -> MS : send MFA code
  MS --> AS : code sent
  AS -> AL : log MFA sent
  AS --> FE : MFA required
else invalid credentials
  AS -> AL : log failed login
  AS --> FE : login error
end

User -> FE : Enter MFA code
FE -> AR : POST /verify-mfa
AR -> LC : verify MFA
LC -> AS : verify_mfa(username, code)
AS -> MS : verify code

alt MFA success
  MS --> AS : valid
  AS -> AL : log success
  AS --> FE : authenticated with role
else MFA failure
  MS --> AS : invalid
  AS -> AL : log failure
  AS --> FE : error
end

@enduml