@startuml Case View 
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

title Context / Use Case View - CJ Secure

actor Provider
actor Patient
actor Admin

rectangle "CJ Secure Portal" {
  usecase "Check Email" as UC1
  usecase "Login + MFA" as UC2
  usecase "Register Account" as UC3
  usecase "Access Records" as UC4
  usecase "View Patient Dashboard" as UC5
  usecase "Review Audit Logs" as UC6
}

' Core interactions only
Provider --> UC4

Patient --> UC3
Patient --> UC5

Admin --> UC6

@enduml