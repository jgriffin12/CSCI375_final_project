@startuml
left to right direction

actor Patient
actor Provider
actor Admin

rectangle "CJ Secure Portal" {
  usecase "Login" as UC1
  usecase "Verify MFA" as UC2
  usecase "View Protected Record" as UC3
  usecase "View Masked Patient Data" as UC4
  usecase "Review Audit Logs" as UC5
}

Patient --> UC1
Patient --> UC2
Patient --> UC3

Provider --> UC1
Provider --> UC2
Provider --> UC3
Provider --> UC4

Admin --> UC1
Admin --> UC2
Admin --> UC5

UC1 --> UC2 : requires
UC3 --> UC4 : protects data

@enduml