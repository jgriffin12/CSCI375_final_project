@startuml
title CJ Secure - Physical Deployment View

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultFontSize 18
skinparam titleFontSize 26
skinparam nodeFontSize 20
skinparam artifactFontSize 17
skinparam ArrowFontSize 16
skinparam linetype ortho

top to bottom direction

node "User Browser" as Browser {
  artifact "CJ Secure UI" as UI
}

node "Frontend (Static Files)" as Frontend {
  artifact "HTML / CSS / JS" as Static
}

node "Docker Backend" as Backend {
  artifact "Flask API" as API
}

database "Data Storage" as Data {
  artifact "users.json" as Users
  artifact "audit_log.txt" as Logs
}

' Connections 
Browser --> Frontend : loads UI
Browser --> Backend : API requests

Frontend --> Backend : HTTP calls

Backend --> Data : read/write data

note right of Logs
Audit log tracks:
login, MFA, records,
admin actions, logout
end note

@enduml