@startuml Physical Deployment

node "User Browser" {
  artifact "CJ Secure Frontend"
}

node "GitHub Pages" {
  artifact "Static HTML/CSS/JS"
}

node "Render or Local Docker" {
  artifact "Flask Backend API"
}

database "Data Files / Repository Layer" {
  artifact "users / records / audit logs"
}

"User Browser" --> "GitHub Pages" : loads frontend
"User Browser" --> "Render or Local Docker" : API requests
"Render or Local Docker" --> "Data Files / Repository Layer" : read/write data

@enduml