@startuml
skinparam shadowing false

title Physical View - Deployment Diagram

node "User Device" {
  artifact "Browser" as Browser
}

node "Docker Host" {
  node "Web Application Container" {
    artifact "Python Flask Web App" as App
    artifact "Authentication Logic" as Auth
    artifact "MFA Logic" as MFAApp
    artifact "RBAC Logic" as RBAC
    artifact "Record Service" as RecordSvc
    artifact "Audit Logger" as Audit
  }

  database "Application Database" as DB
}

node "External Service" {
  artifact "MFA Provider" as MFAProvider
}

Browser --> App : HTTPS
App --> Auth
App --> MFAApp
App --> RBAC
App --> RecordSvc
App --> Audit
App --> DB : read/write users,\nroles, records, logs
MFAApp --> MFAProvider : send/verify codes
@enduml