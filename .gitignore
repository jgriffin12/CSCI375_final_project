# Python cache / compiled files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Pytest
.pytest_cache/

# Mypy
.mypy_cache/

# Coverage
.coverage
.coverage.*
htmlcov/

# Build artifacts
build/
dist/
*.egg-info/

# VS Code / Codespaces
.vscode/
.history/

# OS files
.DS_Store
Thumbs.db

# Node / npm
node_modules/
npm-debug.log*

# Generated UML exports (ignore all images/docs by default)
*.png
*.pdf
*.svg

# Allow UML screenshots + exports
!Docs/
!Docs/Uml/
!Docs/Uml/dist_puml/

!Docs/Uml/*.png
!Docs/Uml/dist_puml/*.png
!Docs/Uml/*.pdf
!Docs/Uml/dist_puml/*.pdf

# Environment variables / secrets
.env
.env.*
*.env
!.env.example

# Local demo user storage
data/users.json
data/audit_log.txt
